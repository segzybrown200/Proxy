{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "jsx": "react-jsx",
    "types": ["nativewind/types"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "api/*": ["api/*"],
      "components/*": ["components/*"],
      "global/*": ["global/*"],
      "hooks/*": ["hooks/*"],
      "utils/*": ["utils/*"]
    }
  }
}